rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      // Herkes okuyabilir (müşteriler viewer'dan okur)
      allow read: if true;
      // Sadece yazma (admin panelinden) — TEST MODUNDA açık
      // CANLI SISTEME ALMADAN ÖNCE auth kontrolü ekleyin!
      allow write: if true;
    }
  }
}
